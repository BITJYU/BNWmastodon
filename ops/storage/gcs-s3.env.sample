############################
# GCP Cloud Storage via Mastodon's S3 backend
# Copy these values into .env.production for production use.
############################

# Enable object storage
S3_ENABLED=true

# GCS S3-compatible endpoint
S3_PROTOCOL=https
S3_REGION=auto
S3_HOSTNAME=storage.googleapis.com
S3_ENDPOINT=https://storage.googleapis.com

# Bucket and credentials
S3_BUCKET=your-gcs-bucket-name
AWS_ACCESS_KEY_ID=your-gcs-hmac-access-key
AWS_SECRET_ACCESS_KEY=your-gcs-hmac-secret

# Uploaded media host
# Recommended:
# 1. Put Cloud CDN / HTTPS LB in front of the bucket, or
# 2. Use a dedicated media domain that points at the bucket origin.
S3_ALIAS_HOST=media.example.com

# S3 backend tuning
S3_SIGNATURE_VERSION=v4
S3_PERMISSION=public-read
S3_MULTIPART_THRESHOLD=52428800
S3_OPEN_TIMEOUT=5
S3_READ_TIMEOUT=5

# Optional
# S3_STORAGE_CLASS=STANDARD
# S3_FORCE_SINGLE_REQUEST=false
# S3_ENABLE_CHECKSUM_MODE=false

# Keep local filesystem storage disabled once cutover is complete
# PAPERCLIP_ROOT_PATH=
# PAPERCLIP_ROOT_URL=
